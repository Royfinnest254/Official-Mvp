{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "Select your Supabase PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres"
    },
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select your Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "Institutional high-density coordination monitor for Connex Ledger.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "CORE NETWORK HEALTH & SYSTEM STABILITY",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 70 },
              { "color": "#ef4444", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [{ "expr": "100 - (avg by (app) (rate(process_cpu_seconds_total[1m])) * 100)", "refId": "A" }],
      "title": "CPU RESOURCE AVAILABILITY",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
             "mode": "absolute",
             "steps": [
               { "color": "#38bdf8", "value": null }
             ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [{ "expr": "process_resident_memory_bytes", "refId": "A" }],
      "title": "RESIDENT MEMORY ALLOCATION",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#475569", "value": null },
              { "color": "#10b981", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "minVizHeight": 10,
        "minVizWidth": 10,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "valueSize": 12 }
      },
      "targets": [{ "expr": "connex_witness_node_status", "legendFormat": "{{node_id}}", "refId": "A" }],
      "title": "WITNESS QUORUM CONNECTIVITY PULSE",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "INSTITUTIONAL PERFORMANCE & SETTLEMENT LATENCY",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#38bdf8" },
          "custom": {
            "axisLabel": "TPS",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "stepAfter",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{ "expr": "rate(connex_transactions_total[2m])", "legendFormat": "{{institution_a}} → {{institution_b}}", "refId": "A" }],
      "title": "INSTITUTIONAL THROUGHPUT (OPS)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
             "drawStyle": "line",
             "fillOpacity": 15,
             "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 0.25 },
              { "color": "#ef4444", "value": 0.5 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(connex_consensus_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum(rate(connex_consensus_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "B" }
      ],
      "title": "CONSENSUS FINALITY SPREAD",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
      "title": "LEDGER ACTIVITY & AUDIT DISTRIBUTION",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 6, "w": 10, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [{ "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route, status_code)", "legendFormat": "{{route}} ({{status_code}})", "refId": "A" }],
      "title": "GATEWAY TRAFFIC ANALYSIS",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_POSTGRESQL}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 14, "x": 10, "y": 15 },
      "id": 8,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "format": "table", "rawSql": "SELECT event_type as \"Type\", count(*) as \"Volume\" FROM public.coordination_records GROUP BY 1", "refId": "A" }],
      "title": "LEDger EVENT DISTRIBUTION (POSTGRESQL)",
      "type": "piechart"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["institutional", "fintech", "slated"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "utc",
  "title": "CONNEX INSTITUTIONAL LEDGER | V2.1",
  "uid": "connex-institutional-v2-1",
  "version": 1
}
